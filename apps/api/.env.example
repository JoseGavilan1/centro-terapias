# Copiar a .env y ajustar valores. NUNCA commitear el archivo .env.

# --- Servidor ---
PORT=3001
# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000

# --- Base de datos (docker compose up -d levanta esta instancia) ---
DATABASE_URL=postgresql://centro:centro_dev@localhost:5432/centro_terapias?schema=public

# --- Autenticación ---
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=cambiar-por-secreto-largo-y-aleatorio
# Vida del access token en segundos (15 minutos)
JWT_ACCESS_TTL=900
# Vida del refresh token en días
REFRESH_TOKEN_TTL_DAYS=7
# true en producción (requiere HTTPS)
COOKIE_SECURE=false

# --- Seed inicial (solo primera ejecución) ---
SEED_ORG_NAME=Centro de Terapias Demo
SEED_ADMIN_EMAIL=admin@demo.cl
SEED_ADMIN_PASSWORD=Admin123!

# --- Documentos (Módulo 5) ---
# local-disk (desarrollo/test, sin credenciales): escribe en DOCUMENT_STORAGE_LOCAL_DIR.
# google-drive (producción): requiere las tres variables GOOGLE_DRIVE_* de abajo.
DOCUMENT_STORAGE_DRIVER=local-disk
# Tamaño máximo por archivo, en bytes (default 15 MB)
DOCUMENTS_MAX_UPLOAD_BYTES=15728640
# Solo con DOCUMENT_STORAGE_DRIVER=local-disk (default: ./storage)
DOCUMENT_STORAGE_LOCAL_DIR=storage

# Solo con DOCUMENT_STORAGE_DRIVER=google-drive:
# Email de la cuenta de servicio de Google Cloud con acceso a Drive API.
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
# Clave privada RSA de la cuenta de servicio (formato PEM); si se pasa como variable de
# entorno de una sola línea, escapar los saltos de línea como "\n".
GOOGLE_DRIVE_PRIVATE_KEY=
# Id de la carpeta raíz de Drive bajo la cual se crean las carpetas por paciente.
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# --- WhatsApp (Módulo 6) ---
# console (desarrollo/test, sin credenciales): registra el envío en whatsapp_messages y consola.
# whatsapp-cloud-api (producción): requiere las tres variables WHATSAPP_* de abajo.
MESSAGING_DRIVER=console

# Solo con MESSAGING_DRIVER=whatsapp-cloud-api:
# Token de la cuenta de sistema de Meta (envía en nombre de todos los phone_number_id registrados).
WHATSAPP_ACCESS_TOKEN=
# Secreto de la app de Meta; verifica la firma X-Hub-Signature-256 del webhook entrante.
WHATSAPP_APP_SECRET=
# Token propio que se configura en el panel de Meta para el handshake GET del webhook.
WHATSAPP_VERIFY_TOKEN=
